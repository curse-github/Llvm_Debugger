msgstr ""
"  -p, --prefix=STRING\n"
"         reformira samo retke koji započinju sa STRINGOM,\n"
"         ali nakon formiranja prikvači STRING tim redcima\n"

#: src/fmt.c:286
msgid ""
"  -s, --split-only\n"
