msgstr "  -A, --show-all           ekvivalentno s -vET\n"

#: src/cat.c:106
msgid "  -b, --number-nonblank    number nonempty output lines, overrides -n\n"
msgstr ""
"  -b, --number-nonblank    broj ne-praznih izlaznih redaka, nadvlada -n\n"

